{
  "name": "sample-be",
  "version": "0.0.1",
  "private": true,
  "description": "",
  "license": "UNLICENSED",
  "author": "Sina Akbari Shadbad",
  "scripts": {
    "build": "nest build",
    "db:identity-service:migration:down": "typeorm -d apps/identity-service/src/database/data-source.ts migration:revert",
    "db:identity-service:migration:generate": "typeorm -d apps/identity-service/src/database/data-source.ts migration:generate apps/identity-service/src/database/migrations/$npm_config_name",
    "db:identity-service:migration:up": "typeorm -d apps/identity-service/src/database/data-source.ts migration:run",
    "db:identity-service:seed": "ts-node apps/identity-service/src/database/seeds/seed.ts",
    "db:user-service:migration:down": "typeorm -d apps/user-service/src/database/data-source.ts migration:revert",
    "db:user-service:migration:generate": "typeorm -d apps/user-service/src/database/data-source.ts migration:generate apps/user-service/src/database/migrations/$npm_config_name",
    "db:user-service:migration:up": "typeorm -d apps/user-service/src/database/data-source.ts migration:run",
    "db:user-service:seed": "ts-node apps/user-service/src/database/seeds/seed.ts",
    "dev": "npm run infra:up && concurrently \"nest start api-gateway --watch\" \"nest start identity-service --watch\" \"nest start user-service --watch\"",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "infra:down": "docker compose down",
    "infra:up": "docker compose up -d && sleep 4 && ./scripts/init-pubsub.sh",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/apps/sample-be/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/sample-be/test/jest-e2e.json",
    "test:watch": "jest --watch",
    "type:check": "tsc --noEmit"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@libs/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@libs/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@libs/core(|/.*)$": "<rootDir>/libs/core/src/$1",
      "^@libs/infra(|/.*)$": "<rootDir>/libs/infra/src/$1",
      "^libs/core(|/.*)$": "<rootDir>/libs/core/src/$1"
    },
    "rootDir": ".",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  },
  "dependencies": {
    "@google-cloud/pubsub": "^5.3.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@golevelup/ts-jest": "^3.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
