# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or any file containing real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Gateway (port 3000) ───────────────────────────────────────────────────
PORT=3000
IDENTITY_SERVICE_URL=http://localhost:3002
USER_SERVICE_URL=http://localhost:3001

# ── Identity Service (port 3002) ──────────────────────────────────────────────
# PORT=3002
# DATABASE_URL=postgresql://dev:dev@localhost:5432/identity_db

# ── User Service (port 3001) ──────────────────────────────────────────────────
# PORT=3001
# DATABASE_URL=postgresql://dev:dev@localhost:5432/users_db

# ── JWT (shared between gateway and identity-service) ─────────────────────────
JWT_SECRET=local-dev-secret-change-in-production
JWT_EXPIRES_IN=15m

# ── Google Cloud Pub/Sub ──────────────────────────────────────────────────────
PUBSUB_PROJECT_ID=local-dev
# Set this when using the local emulator; omit in production GCP environments.
PUBSUB_EMULATOR_HOST=localhost:8085
